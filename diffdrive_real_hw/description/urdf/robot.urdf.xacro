<?xml version="1.0"?>
<robot name="diff_bot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ================================================================ -->
  <!--  Parameters  — edit to match your robot                           -->
  <!-- ================================================================ -->
  <xacro:property name="base_length"      value="0.200"/>
  <xacro:property name="base_width"       value="0.180"/>
  <xacro:property name="base_height"      value="0.080"/>
  <xacro:property name="wheel_radius"     value="0.033"/>
  <xacro:property name="wheel_thickness"  value="0.020"/>
  <xacro:property name="wheel_separation" value="0.160"/>

  <!-- ================================================================ -->
  <!--  Links & Joints                                                    -->
  <!-- ================================================================ -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
      <material name="blue"><color rgba="0.2 0.4 0.8 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/>
    </inertial>
  </link>

  <xacro:macro name="wheel" params="name y_reflect">
    <link name="${name}">
      <visual>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_thickness}"/></geometry>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
      </visual>
      <collision>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_thickness}"/></geometry>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      </collision>
      <inertial>
        <mass value="0.2"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0002"/>
      </inertial>
    </link>
    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${name}"/>
      <origin xyz="0 ${y_reflect * wheel_separation / 2} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel name="left_wheel"  y_reflect=" 1"/>
  <xacro:wheel name="right_wheel" y_reflect="-1"/>

  <!-- Caster -->
  <link name="caster_link">
    <visual>
      <geometry><sphere radius="${wheel_radius / 2}"/></geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1.0"/></material>
    </visual>
    <collision><geometry><sphere radius="${wheel_radius / 2}"/></geometry></collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="caster_link"/>
    <origin xyz="${base_length/2 - 0.02} 0 ${-wheel_radius/2}" rpy="0 0 0"/>
  </joint>

  <!-- ================================================================ -->
  <!--  ros2_control hardware interface block                             -->
  <!--                                                                   -->
  <!--  Plugin: esp32_hardware/Esp32HardwareInterface                    -->
  <!--  Parameters are read by on_init() in the C++ plugin.              -->
  <!--                                                                   -->
  <!--  serial_port: your ESP32's USB serial device                      -->
  <!--  baud_rate:   must match Serial.begin() in firmware               -->
  <!-- ================================================================ -->
  <ros2_control name="esp32_hardware" type="system">
    <hardware>
      <plugin>esp32_hardware/Esp32HardwareInterface</plugin>
      <param name="serial_port">/dev/serial/by-id/usb-1a86_USB_Serial-if00-port0</param>   <!-- ← edit this -->
      <param name="baud_rate">921600</param>
    </hardware>

    <!-- Joint order: index 0 = left, 1 = right (matches ESP32 firmware) -->
    <joint name="left_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-9.0</param>   <!-- rad/s, matches MAX_VEL in firmware -->
        <param name="max"> 9.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="right_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-9.0</param>
        <param name="max"> 9.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

</robot>
